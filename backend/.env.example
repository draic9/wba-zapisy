TPAY_ENV=sandbox

# OAuth/transactions URLs are derived from TPAY_ENV by default.
# You can override them if needed:
# TPAY_OAUTH_URL=https://openapi.sandbox.tpay.com/oauth/auth
# TPAY_TRANSACTIONS_URL=https://openapi.sandbox.tpay.com/transactions

TPAY_CLIENT_ID=
TPAY_CLIENT_SECRET=
TPAY_MERCHANT_ID=
TPAY_MD5_CODE=

# Optional override (defaults to TPAY_ENV)
# TPAY_JWS_MODE=sandbox

# Used only in sandbox/local testing to expose webhook publicly
# NGROK_URL=https://xxxx.ngrok-free.app

# Public base URLs
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Postgres
PGHOST=localhost
PGUSER=postgres
PGPASSWORD=
PGDATABASE=wba_zapisy
PGPORT=5432

# SMTP
SMTP_HOST=smtp.gmail.com
